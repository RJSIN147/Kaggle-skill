# Kaggle API credentials — fill with REAL values, then keep this file private.
# This .env is gitignored (D-05) and MUST NEVER be committed. The runner sources
# it (bash: `set -a; source .env; set +a`) to set KAGGLE_* per run.
#
# Get a token at https://www.kaggle.com/settings -> "Create New Token".
# Env vars are canonical (D-04); leave the values blank until you fill them in.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Alternatively, a single API token can be used instead of username/key:
# KAGGLE_API_TOKEN=
